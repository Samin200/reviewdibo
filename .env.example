# Frontend → backend URL.
# Set to your FastAPI backend URL (e.g. http://localhost:8000 for local dev,
# or https://reviewdibo.onrender.com for production on Render).
# Leave EMPTY to use the built-in Next.js API routes instead (local dev without FastAPI).
NEXT_PUBLIC_API_URL=https://reviewdibo.onrender.com

# Database URL — only needed when NEXT_PUBLIC_API_URL is empty (built-in API routes).
# Not needed when proxying to a FastAPI backend.
# DATABASE_URL=postgresql://user:password@localhost:5432/reviewdibo

# JWT secret — only needed when NEXT_PUBLIC_API_URL is empty (built-in API routes).
# Not needed when proxying to a FastAPI backend.
# JWT_SECRET=dev-secret-change-in-production
