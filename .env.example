# Frontend → backend URL.
# Leave EMPTY to use the built-in Next.js API routes (relative /api/*).
# Set to http://localhost:8000 to use the standalone FastAPI backend in /backend.
NEXT_PUBLIC_API_URL=

# Database connection used by the built-in Next.js API routes (Drizzle/Postgres).
DATABASE_URL=postgresql://user:password@localhost:5432/reviewdibo

# JWT secret for auth tokens. Change this in production!
JWT_SECRET=dev-secret-change-in-production
